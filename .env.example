# Google Cloud Configuration
GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_PRIVATE_KEY_ID=your-private-key-id
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key-here\n-----END PRIVATE KEY-----\n"
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/your-service-account%40your-project.iam.gserviceaccount.com

# Satellite Supabase project (separate from main app)
VITE_SUPABASE_URL=https://your-satellite-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-satellite-supabase-anon-key
VITE_API_BASE_URL=https://your-satellite-project.supabase.co/functions/v1

# Server Configuration
PORT=3001
NODE_ENV=development

# Logging
LOG_LEVEL=info

# Google Maps API Key (for polygon drawing and geocoding)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
