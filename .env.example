# Google Cloud Configuration
GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_PRIVATE_KEY_ID=your-private-key-id
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-private-key-here\n-----END PRIVATE KEY-----\n"
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/your-service-account%40your-project.iam.gserviceaccount.com

# Satellite Supabase project (separate from main app)
VITE_SUPABASE_URL=https://your-satellite-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-satellite-supabase-anon-key
VITE_API_BASE_URL=https://your-satellite-project.supabase.co/functions/v1

# Mobile app backend auth account. The email defaults to jashvinu@wrkfarm.com
# in code; set the password only in local .env, CI secrets, or --dart-define.
BACKEND_AUTH_EMAIL=jashvinu@wrkfarm.com
BACKEND_AUTH_PASSWORD=your-backend-auth-password

# Supabase Edge Function secrets for diagnostics and disease photo diagnosis.
# Set these with `supabase secrets set ...` in the linked Supabase project.
SUPABASE_URL=https://your-satellite-project.supabase.co
SUPABASE_ANON_KEY=your-satellite-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-satellite-service-role-key
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"your-gcp-project-id","private_key":"-----BEGIN PRIVATE KEY-----\\nyour-private-key\\n-----END PRIVATE KEY-----\\n","client_email":"your-service-account@your-project.iam.gserviceaccount.com"}
VLM_API_KEY=your-openai-compatible-vision-api-key
VLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
VLM_MODEL=qwen-vl-max

# RAG knowledge-base embeddings (agronomy_knowledge). Reuses QWEN_API_KEY and
# QWEN_BASE_URL by default; override only if the embedding endpoint differs.
QWEN_EMBED_MODEL=text-embedding-v3
# QWEN_EMBED_API_KEY=your-embedding-api-key
# QWEN_EMBED_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Optional shared secret to gate the one-off knowledge-ingest function.
# INGEST_SECRET=your-ingest-secret

# Server Configuration
PORT=3001
NODE_ENV=development

# Logging
LOG_LEVEL=info

# Grain grading runs in Supabase Edge Functions (grain-grade, grain-grade-feedback,
# grain-crops) and reuses the VLM_* Qwen key above plus SUPABASE_SERVICE_ROLE_KEY.
# No separate grading host is needed. See docs/11_grain_grading_integration.md.

# Public web app base URL used inside harvest QR codes. Camera/Google Lens scans
# open PUBLIC_TRACE_BASE_URL/#/trace/<token>.
PUBLIC_TRACE_BASE_URL=https://your-public-grainright-app.example

# MapTiler Cloud key for field imagery, offline map downloads, and place search.
# Local IO debug builds read this .env file after RuntimeConfig.initialize().
# Web builds still need --dart-define or a deployed runtime config strategy.
# Do not commit real keys.
MAPTILER_API_KEY=your-maptiler-api-key

# Optional full tile templates. Use only providers whose terms allow your use.
# ONLINE_SATELLITE_TILE_URL_TEMPLATE=https://api.maptiler.com/maps/hybrid/256/{z}/{x}/{y}@2x.jpg?key=your-maptiler-api-key
# OFFLINE_TILE_URL_TEMPLATE=
