# Copy this file to .env and fill in local values.
# Never commit real API keys.

QWEN_VL_PROVIDER=dashscope
QWEN_VL_API_KEY=

# Supabase app backend integration.
# Frontend/mobile should use SUPABASE_ANON_KEY. Only FastAPI/worker may use the service role key.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_AUTH_REQUIRED=1
SUPABASE_GRAIN_BUCKET=grain-images
SUPABASE_MOISTURE_BUCKET=moisture-images
SUPABASE_ANALYSIS_TABLE=analysis_jobs
SUPABASE_ANALYSIS_LOGS_TABLE=analysis_logs
SUPABASE_CORRECTIONS_TABLE=operator_corrections
SUPABASE_HTTP_TIMEOUT_SECONDS=30

# When enabled, /api/v1/analysis/{id}/submit returns immediately and runs grading
# in the API process background. Set to 0 when deploying a separate grading-worker.
GRADING_BACKGROUND_ON_SUBMIT=0
GRADING_WORKER_POLL_SECONDS=3
GRADING_WORKER_BATCH_SIZE=1

# Optional overrides:
# QWEN_VL_MODEL=qwen3-vl-plus
# QWEN_VL_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# QWEN_VL_TIMEOUT_SECONDS=35
# QWEN_VL_ENABLE_THINKING=false
# QWEN_VL_FALLBACK_MODELS=qwen3-vl-flash,qwen-vl-plus

# Provider-specific aliases supported by the app:
# DASHSCOPE_API_KEY=
# SILICONFLOW_API_KEY=

# Optional crop-specific routing map (JSON object or path to JSON file):
# CROP_MODEL_ROUTES='{"rice":{"provider":"dashscope","model":"qwen3-vl-plus","base_url":"https://...","api_key":"..."}}'
# CROP_MODEL_ROUTES_PATH=/path/to/crop_model_routes.json
# Or point to the included sample:
# CROP_MODEL_ROUTES_PATH=scripts/crop_model_routes.example.json
